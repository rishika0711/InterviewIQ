# MongoDB — MongoDB Atlas (free tier) or local MongoDB
# Use the URI from Atlas (Database → Connect → Drivers). If the DB password contains
# special characters (@ : / ? # etc.), encode them in the URI (e.g. # → %23).
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/interviewiq?retryWrites=true&w=majority&appName=interviewiq"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl"
NEXTAUTH_SECRET="generate-with-openssl"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini AI — aistudio.google.com/apikey
GOOGLE_AI_API_KEY=""
# Optional model override (default: gemini-2.5-flash). Other options:
# gemini-flash-latest, gemini-2.5-pro, gemini-2.5-flash-lite.
GOOGLE_AI_MODEL=""
